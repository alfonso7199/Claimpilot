# Copy this file to ".env" and fill in your key.
# Your personal OpenAI API key (platform.openai.com -> API keys).
# NOTE: this is NOT the ChatGPT Plus subscription; it's the pay-as-you-go API.
OPENAI_API_KEY=sk-...

# Model used for the agents (you can switch to a cheaper one for testing).
CLAIMPILOT_MODEL=gpt-4o

# Filled in automatically when you run setup_vectorstore.py
VECTOR_STORE_ID=
